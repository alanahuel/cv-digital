---
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import WhatsappWidget from '../components/WhatsappWidget.astro';
import {
  profile,
  contact,
  experience,
  education,
  languages,
  skills,
} from '../data/cv';

const mailto = `mailto:${profile.email}?subject=${encodeURIComponent(
  contact.emailSubject
)}&body=${encodeURIComponent(contact.emailBody)}`;
const whatsapp = `https://wa.me/${profile.phoneRaw}?text=${encodeURIComponent(
  contact.whatsappMessage
)}`;
const tel = `tel:+${profile.phoneRaw}`;
---

<Layout>
  <main class="mx-auto max-w-3xl px-5 pb-24 pt-16 sm:px-6 sm:pt-24">
    <!-- HERO -->
    <header class="fade-up">
      <p class="mb-3 text-sm font-medium uppercase tracking-[0.2em] text-indigo-300/80">
        {profile.role} · {profile.status}
      </p>
      <h1 class="font-display text-4xl font-bold leading-tight text-white sm:text-6xl">
        {profile.name}
      </h1>
      <p class="mt-4 flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-slate-400">
        <span>{profile.location}</span>
        <span class="text-slate-600">·</span>
        <a href={profile.linkedin} target="_blank" rel="noopener noreferrer"
          class="transition-colors hover:text-indigo-300">{profile.linkedinLabel}</a>
      </p>

      <!-- CTA de contacto -->
      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href={mailto}
          class="group inline-flex items-center gap-2 rounded-full bg-indigo-500 px-5 py-2.5 text-sm font-semibold text-white shadow-lg shadow-indigo-500/25 transition-all hover:bg-indigo-400 hover:shadow-indigo-400/40"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg>
          Enviar correo
        </a>
        <a
          href={whatsapp}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-full border border-emerald-400/40 bg-emerald-400/10 px-5 py-2.5 text-sm font-semibold text-emerald-300 transition-all hover:bg-emerald-400/20"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967c-.273-.099-.471-.148-.67.15c-.197.297-.767.966-.94 1.164c-.173.199-.347.223-.644.075c-.297-.15-1.255-.463-2.39-1.475c-.883-.788-1.48-1.761-1.653-2.059c-.173-.297-.018-.458.13-.606c.134-.133.298-.347.446-.52c.149-.174.198-.298.298-.497c.099-.198.05-.371-.025-.52c-.075-.149-.669-1.612-.916-2.207c-.242-.579-.487-.5-.669-.51l-.57-.01c-.198 0-.52.074-.792.372c-.272.297-1.04 1.016-1.04 2.479c0 1.462 1.065 2.875 1.213 3.074c.149.198 2.096 3.2 5.077 4.487c.709.306 1.262.489 1.694.625c.712.227 1.36.195 1.871.118c.571-.085 1.758-.719 2.006-1.413c.248-.694.248-1.289.173-1.413c-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214l-3.741.982l.998-3.648l-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884c2.64 0 5.122 1.03 6.988 2.898a9.83 9.83 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.886 9.884"></path></svg>
          WhatsApp
        </a>
        <a
          href={profile.cvFile}
          download
          class="inline-flex items-center gap-2 rounded-full border border-white/15 px-5 py-2.5 text-sm font-semibold text-slate-200 transition-all hover:border-white/30 hover:bg-white/5"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
          Descargar CV
        </a>
      </div>
      <div class="mt-4 flex flex-wrap gap-x-5 gap-y-1 text-sm text-slate-400">
        <a href={tel} class="transition-colors hover:text-indigo-300">{profile.phone}</a>
        <a href={`mailto:${profile.email}`} class="transition-colors hover:text-indigo-300">{profile.email}</a>
      </div>
    </header>

    <!-- PERFIL -->
    <Section title="Perfil" id="perfil">
      <p class="text-lg leading-relaxed text-slate-300">{profile.summary}</p>
    </Section>

    <!-- EXPERIENCIA -->
    <Section title="Experiencia" id="experiencia">
      <ol class="relative ml-1 border-l border-indigo-400/20">
        {
          experience.map((job) => (
            <li class="relative mb-8 pl-7 last:mb-0">
              <span class="absolute -left-[6.5px] top-1.5 h-3 w-3 rounded-full border-2 border-indigo-400 bg-[#020617]"></span>
              <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
                <h3 class="text-lg font-semibold text-white">
                  {job.role} <span class="text-indigo-300">— {job.company}</span>
                </h3>
                <span class="shrink-0 text-sm text-slate-500">{job.period}</span>
              </div>
              <p class="mt-0.5 text-sm italic text-slate-400">{job.meta}</p>
              <ul class="mt-3 space-y-2">
                {job.bullets.map((b) => (
                  <li class="flex gap-2.5 text-slate-300">
                    <span class="mt-2 h-1 w-1 shrink-0 rounded-full bg-indigo-400/70"></span>
                    <span class="leading-relaxed">{b}</span>
                  </li>
                ))}
              </ul>
            </li>
          ))
        }
      </ol>
    </Section>

    <!-- FORMACIÓN -->
    <Section title="Formación" id="formacion">
      {
        education.map((ed) => (
          <div class="glass glass-top relative p-6">
            <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
              <h3 class="text-lg font-semibold text-white">
                {ed.title} <span class="font-normal text-slate-400">— {ed.subtitle}</span>
              </h3>
              <span class="shrink-0 text-sm text-slate-500">{ed.meta}</span>
            </div>
            <p class="mt-2 leading-relaxed text-slate-400">{ed.note}</p>
          </div>
        ))
      }
    </Section>

    <!-- HABILIDADES -->
    <Section title="Habilidades técnicas" id="habilidades">
      <div class="grid gap-4 sm:grid-cols-2">
        {
          skills.map((group) => (
            <div class="glass p-5">
              <h3 class="mb-3 text-sm font-semibold uppercase tracking-wide text-indigo-300">
                {group.label}
              </h3>
              <ul class="flex flex-wrap gap-2">
                {group.items.map((item) => (
                  <li class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-sm text-slate-300">
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </Section>

    <!-- IDIOMAS -->
    <Section title="Idiomas" id="idiomas">
      <div class="grid gap-4 sm:grid-cols-2">
        {
          languages.map((lang) => (
            <div class="glass flex items-baseline justify-between gap-3 p-5">
              <span class="font-semibold text-white">{lang.name}</span>
              <span class="text-right text-sm text-slate-400">{lang.level}</span>
            </div>
          ))
        }
      </div>
    </Section>

    <!-- CIERRE / CONTACTO -->
    <Section title="¿Hablamos?" id="contacto">
      <div class="glass glass-top relative p-7 text-center sm:p-10">
        <p class="mx-auto max-w-xl text-lg leading-relaxed text-slate-300">
          Si buscás un colaborador técnico autónomo para construir producto y automatizar
          tu operativa interna, escribime y lo vemos.
        </p>
        <div class="mt-7 flex flex-wrap justify-center gap-3">
          <a
            href={mailto}
            class="inline-flex items-center gap-2 rounded-full bg-indigo-500 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-indigo-500/25 transition-all hover:bg-indigo-400"
          >
            Enviar correo
          </a>
          <a
            href={whatsapp}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-full border border-emerald-400/40 bg-emerald-400/10 px-6 py-3 text-sm font-semibold text-emerald-300 transition-all hover:bg-emerald-400/20"
          >
            Escribir por WhatsApp
          </a>
        </div>
      </div>
    </Section>

    <footer class="mt-16 border-t border-white/5 pt-8 text-center text-sm text-slate-500">
      © {new Date().getFullYear()} {profile.name} · {profile.location}
    </footer>
  </main>

  <WhatsappWidget />
</Layout>
